# Copy this file to .env and fill in the two required values before running
# `docker compose up -d`. Everything else has a sane default.

# Required. Generate with: openssl rand -hex 32
# This signs gallery-access cookies — keep it stable across restarts (changing
# it logs out every client from every gallery) and never commit it.
SESSION_SECRET=

# Required in practice. The public URL clients will use to reach this app,
# e.g. https://photos.yourdomain.com — used to build absolute gallery links.
PUBLIC_BASE_URL=http://localhost:3000

# Optional. How many photos to process (thumbnail/preview generation)
# concurrently in the background. Tune down on lower-core NAS hardware.
UPLOAD_CONCURRENCY=4
