# Everything here is OPTIONAL — `docker compose up -d` works with no .env at
# all. Copy this file to .env only if you want to override a default.

# Cookie-signing key. Auto-generated on first boot and persisted to
# ./data/db/session-secret if unset. Provide your own (openssl rand -hex 32)
# only if you want to manage/rotate the key yourself. Changing it logs every
# client out of every gallery.
#SESSION_SECRET=

# How many photos process (thumbnail/preview generation) concurrently in the
# background. Lower on low-core or low-RAM hardware — image processing is the
# app's main memory consumer.
#UPLOAD_CONCURRENCY=4

# Per-file upload size limit in bytes (default 50MB).
#MAX_UPLOAD_FILE_SIZE_BYTES=52428800
