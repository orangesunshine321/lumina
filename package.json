{
  "name": "lumina",
  "version": "1.11.1",
  "description": "Self-hosted client photo galleries with a Lightroom pick-list export",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -n web,server -c blue,green \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "vite build",
    "start": "NODE_ENV=production tsx src/server/index.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/server/db/migrate.ts",
    "test": "vitest run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/compress": "^9.0.0",
    "@fastify/cookie": "^11.1.0",
    "@fastify/multipart": "^10.1.0",
    "@fastify/static": "^9.3.0",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@node-rs/argon2": "^2.0.2",
    "@tanstack/react-query": "^5.101.2",
    "@uppy/core": "^5.2.0",
    "@uppy/dashboard": "^5.1.1",
    "@uppy/react": "^5.2.0",
    "@uppy/xhr-upload": "^5.2.0",
    "archiver": "^8.0.0",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "exifr": "^7.1.3",
    "fastify": "^5.10.0",
    "jose": "^6.2.3",
    "nanoid": "^5.1.16",
    "otpauth": "^9.5.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-photo-album": "^3.6.0",
    "react-router-dom": "^7.18.1",
    "sharp": "^0.35.3",
    "thumbhash": "^0.1.1",
    "tsx": "^4.23.0",
    "yet-another-react-lightbox": "^3.32.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/archiver": "^8.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "playwright-core": "^1.61.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
